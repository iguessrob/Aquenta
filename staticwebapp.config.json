{
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/assets/images/*", "/styles/*", "/script/*", "/*.css", "/*.js", "/*.png", "/*.jpg", "/*.svg"]
  },
  "routes": [
    {
      "route": "/index.html",
      "redirect": "/",
      "statusCode": 301
    }
  ]
}
